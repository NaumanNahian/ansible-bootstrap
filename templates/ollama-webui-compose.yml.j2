services:
  # Ollama: Local Large Language Model Runner
  ollama:
    image: ollama/ollama:0.5.12
    container_name: ollama
    restart: unless-stopped
    volumes:
      - ollama_data:/root/.ollama

  # Open WebUI: User-friendly web interface for Ollama
  open-webui:
    image: ghcr.io/open-webui/open-webui:v0.5.17
    container_name: open-webui
    restart: unless-stopped
    ports:
      - "127.0.0.1:3000:8080"
    environment:
      - OLLAMA_BASE_URL=http://ollama:11434
      - WEBUI_SECRET_KEY={{ open_webui_secret_key }}
      - WEBUI_AUTH=true
    volumes:
      - open-webui_data:/app/backend/data
    depends_on:
      - ollama

volumes:
  ollama_data:
  open-webui_data:
